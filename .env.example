# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real credentials.

# ─── Firebase / Firestore ────────────────────────────────────────────────────

# The Firebase project ID. You'll see it in the Firebase console URL.
# Example: fundraiser-hub-prod-a1b2c3
FIREBASE_PROJECT_ID=

# ONE of these two must be set:
#
# (1) Recommended for Vercel: paste the entire service account JSON as a
#     single-line string. On Vercel set it via the dashboard so it does not
#     hit the filesystem.
#
#     FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
#
# (2) Local dev: point at the JSON key file on disk.
#
#     GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
#
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Access control ──────────────────────────────────────────────────────────

# Random secret used to sign the unlock cookies. Anything 32+ random bytes.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNLOCK_COOKIE_SECRET=

# The master code that unlocks every fundraiser. Pick something the
# Fundraiser Overseer can remember but not trivially guessable. Defaults to
# "admin-2026" if unset (only acceptable in development).
MASTER_ACCESS_CODE=

# ─── Dev convenience ─────────────────────────────────────────────────────────

# Set to 1 to run the UI entirely against in-process mock data, bypassing
# the API + Firestore. Useful for design work when Firebase isn't configured.
NEXT_PUBLIC_USE_MOCK_DATA=0
